generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phoneNumber String
  industry    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User?
  aiConfiguration AIConfiguration?
  knowledgeBase   KnowledgeBase?

  aiEvaluations AIEvaluation[]
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model AIConfiguration {
  id             String   @id @default(uuid())
  systemPrompt   String
  language       String   @default("fr")
  voice          String   @default("default")
  welcomeMessage String   @default("Bonjour, comment puis-je vous aider ?")
  temperature    Float    @default(0.3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum KnowledgeSourceType {
  TEXT
  FAQ
  PDF
  WORD
}
enum AIEvaluationMode {
  ASK
  COMPARE
}

enum AIEvaluationStatus {
  SUCCESS
  ERROR
}

enum AIProviderType {
  OPENAI
  ANTHROPIC
}

model KnowledgeBase {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  documents KnowledgeDocument[]
}

model KnowledgeDocument {
  id         String              @id @default(uuid())
  title      String
  category   String?
  content    String
  sourceType KnowledgeSourceType @default(TEXT)
  isActive   Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
}

model AIEvaluation {
  id        String           @id @default(uuid())
  question  String
  mode      AIEvaluationMode
  createdAt DateTime         @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  results AIModelResult[]

  @@index([companyId, createdAt])
}

model AIModelResult {
  id           String             @id @default(uuid())
  provider     AIProviderType
  model        String
  answer       String?
  latencyMs    Int?
  inputTokens  Int?
  outputTokens Int?
  status       AIEvaluationStatus
  errorMessage String?
  createdAt    DateTime           @default(now())

  evaluationId String
  evaluation   AIEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([provider, createdAt])
}
